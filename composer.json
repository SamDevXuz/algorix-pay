{
    "name": "samdevxuz/algorix-pay",
    "description": "Userbot-based P2P payment receiver for Laravel — listen to bank notification bots (Click, Payme, Uzum) via MTProto and emit PaymentReceived events.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "payment",
        "uzbekistan",
        "click",
        "payme",
        "uzum",
        "mtproto",
        "userbot",
        "p2p"
    ],
    "authors": [
        {
            "name": "SamDevXuz"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "danog/madelineproto": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "AlgorixPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AlgorixPay\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlgorixPay\\AlgorixPayServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
